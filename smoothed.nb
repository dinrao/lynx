Cell[CellGroupData[{

Cell["\<\
Test for differences in slope between white and yellow flowers\
\>", "Subsubsection",
 CellChangeTimes->{{3.956256369964712*^9, 3.956256378305352*^9}, {
  3.98569555109435*^9, 
  3.985695583618692*^9}},ExpressionUUID->"c02b796e-c15e-461a-aa15-\
4c496854a039"],

Cell["", "Text",
 CellChangeTimes->{{3.956256450454813*^9, 3.956256451374551*^9}, 
   3.985695589853736*^9},ExpressionUUID->"bed3663a-8cfd-4bc9-b5bc-\
e926bd65e67a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\n", "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Extract", " ", "parameter", " ", "information", " ", "including", " ", 
    "slopes"}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Get", " ", "the", " ", "slope", " ", "coefficients", " ", "and", " ", 
    "their", " ", "standard", " ", "errors"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"slope1", " ", "=", " ", 
     RowBox[{
      RowBox[{"ymodel", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"slope2", " ", "=", " ", 
     RowBox[{
      RowBox[{"wmodel", "[", "\"\<BestFitParameters\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"stderr1", " ", "=", " ", 
     RowBox[{
      RowBox[{"ymodel", "[", "\"\<ParameterErrors\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"stderr2", " ", "=", " ", 
     RowBox[{
      RowBox[{"wmodel", "[", "\"\<ParameterErrors\>\"", "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Calculate", " ", "the", " ", "difference", " ", "between", " ", 
     "slopes"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"slopeDiff", " ", "=", " ", 
     RowBox[{"slope1", " ", "-", " ", "slope2"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Calculate", " ", "standard", " ", "error", " ", "of", " ", "the", " ", 
     "difference"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"seDiff", " ", "=", " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"stderr1", "^", "2"}], " ", "+", " ", 
       RowBox[{"stderr2", "^", "2"}]}], "]"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Calculate", " ", "t"}], "-", "statistic"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"tStat", " ", "=", " ", 
     RowBox[{"slopeDiff", "/", "seDiff"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Extract", " ", "degrees", " ", "of", " ", "freedom", " ", "from", " ", 
     "ANOVA", " ", "tables", " ", "correctly"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"anovaTable1", " ", "=", " ", 
     RowBox[{"ymodel", "[", "\"\<ANOVATable\>\"", "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"anovaTable2", " ", "=", " ", 
     RowBox[{"wmodel", "[", "\"\<ANOVATable\>\"", "]"}]}], ";"}], "\n", "\n", 
   
   RowBox[{"(*", " ", 
    RowBox[{
    "Find", " ", "the", " ", "Error", " ", "row", " ", "in", " ", "each", " ",
      "ANOVA", " ", "table"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"df1", " ", "=", " ", 
     RowBox[{
      RowBox[{"Cases", "[", 
       RowBox[{"anovaTable1", ",", " ", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\"\<Error\>\"", ",", " ", "df_", ",", " ", "___"}], "}"}], 
         " ", ":>", " ", "df"}], ",", " ", "Infinity"}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"df2", " ", "=", " ", 
     RowBox[{
      RowBox[{"Cases", "[", 
       RowBox[{"anovaTable2", ",", " ", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\"\<Error\>\"", ",", " ", "df_", ",", " ", "___"}], "}"}], 
         " ", ":>", " ", "df"}], ",", " ", "Infinity"}], "]"}], "[", 
      RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Use", " ", "the", " ", "pooled", " ", "degrees", " ", "of", " ", 
     "freedom"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"df", " ", "=", " ", 
     RowBox[{"df1", " ", "+", " ", "df2"}]}], ";"}], "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Calculate", " ", "p"}], "-", 
     RowBox[{"value", " ", 
      RowBox[{"(", 
       RowBox[{"two", "-", 
        RowBox[{"tailed", " ", "test"}]}], ")"}]}]}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"pValue", " ", "=", " ", 
     RowBox[{"2", " ", "*", " ", 
      RowBox[{"(", 
       RowBox[{"1", " ", "-", " ", 
        RowBox[{"CDF", "[", 
         RowBox[{
          RowBox[{"StudentTDistribution", "[", "df", "]"}], ",", " ", 
          RowBox[{"Abs", "[", "tStat", "]"}]}], "]"}]}], ")"}]}]}], ";"}], 
   "\n", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{"Print", " ", "results"}], " ", "*)"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Slope 1: \>\"", ",", " ", "slope1", ",", 
      " ", "\"\< \[PlusMinus] \>\"", ",", " ", "stderr1"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Slope 2: \>\"", ",", " ", "slope2", ",", 
      " ", "\"\< \[PlusMinus] \>\"", ",", " ", "stderr2"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Difference: \>\"", ",", " ", "slopeDiff", ",", 
      " ", "\"\< \[PlusMinus] \>\"", ",", " ", "seDiff"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<t-statistic: \>\"", ",", " ", "tStat"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Degrees of freedom: \>\"", ",", " ", "df"}], "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<p-value: \>\"", ",", " ", "pValue"}], "]"}], ";"}], "\n", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Significant difference at \[Alpha]=0.05: \>\"", ",", " ", 
     RowBox[{"pValue", " ", "<", " ", "0.05"}]}], "]"}], "\n"}]}]], "Input",
 CellChangeTimes->{{3.9562472976967793`*^9, 3.9562473067475233`*^9}, 
   3.9562473832345257`*^9, {3.9562561647665157`*^9, 3.9562561784484463`*^9}, {
   3.956256266220111*^9, 3.956256310939024*^9}, {3.9562563475589523`*^9, 
   3.956256348982439*^9}, {3.956256432683463*^9, 3.956256453820734*^9}, {
   3.985695593981759*^9, 3.985695666110833*^9}},
 CellLabel->
  "In[139]:=",ExpressionUUID->"e3510b1b-d2ba-4a37-8afb-ca58f15b73d1"],

