Cell[CellGroupData[{

Cell["Function to smooth", "Subsubsection",
 CellChangeTimes->{{3.985690431947505*^9, 3.985690450662497*^9}, {
  3.985690716151157*^9, 3.98569071715213*^9}, {3.985690784237482*^9, 
  3.9856907852692213`*^9}, {3.985690853664253*^9, 3.985690858669881*^9}, {
  3.985693493934122*^9, 3.985693539504183*^9}, {3.98569417799644*^9, 
  3.985694193012496*^9}},ExpressionUUID->"48afa7bf-5cad-4cbe-b5e1-\
dc78353a6fc4"],

Cell[BoxData[
 RowBox[{
  RowBox[{"MovingAverageFunction", "[", 
   RowBox[{"Dists_", ",", "Speeds_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"windowSize", ",", "smoothedDistances", ",", "smoothedSpeeds"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"windowSize", "=", "5"}], ";", "\n", 
     RowBox[{"smoothedDistances", "=", 
      RowBox[{"MovingAverage", "[", 
       RowBox[{"Dists", ",", "windowSize"}], "]"}]}], ";", "\n", 
     RowBox[{"smoothedSpeeds", "=", 
      RowBox[{"MovingAverage", "[", 
       RowBox[{"Speeds", ",", "windowSize"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"smoothedDistances", ",", "smoothedSpeeds"}], "}"}], 
       "\[Transpose]"}], "]"}]}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.9856935547535048`*^9, 3.9856936482990713`*^9}, {
  3.9856936839400578`*^9, 3.985693690617558*^9}},
 CellLabel->"In[79]:=",ExpressionUUID->"b97e9e28-368b-4ff6-8cb1-6bc7ca978a38"]
}, Open  ]],

