  RowBox[{"SpecialProximityCut3D", "[", 
   RowBox[{"file_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"head", ",", "obj", ",", "cuts", ",", "cuttraj"}], "}"}], ",", 
    "\n", 
    RowBox[{
     RowBox[{"head", "=", 
      RowBox[{"file", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", "2", ",", "3"}], "}"}]}], "]"}], "]"}]}], ";", 
     "\n", 
