Cell["\<\
Subsample to remove trajectories where computation did not work; standardize \
(z-score normalisation) and then run a low pass filter \
\>", "Text",
 CellChangeTimes->{{3.945517624934432*^9, 
  3.945517682954702*^9}},ExpressionUUID->"25fb10c4-1d73-4361-9d49-\
3a520a4f59cb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"wpv", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"LowpassFilter", "[", 
      RowBox[{
       RowBox[{"PVwhites", "[", 
        RowBox[{"[", "#", "]"}], "]"}], ",", "0.5"}], "]"}], "&"}], "/@", " ", 
    RowBox[{"Range", "@", 
     RowBox[{"Length", "@", "fwhites"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{
  3.94545430281105*^9, {3.945455365125342*^9, 3.9454553771298923`*^9}, {
   3.945455485323493*^9, 3.94545549528323*^9}, 3.945518409551073*^9, {
   3.945700437670952*^9, 3.945700469770876*^9}},
 CellLabel->"In[58]:=",ExpressionUUID->"ec2d3cbb-9d4f-4d25-ae09-ff780556d702"],

Cell["Distances for white flower flights ", "Text",
 CellChangeTimes->{{3.945517590396758*^9, 3.945517596388608*^9}, {
  3.945518432667172*^9, 
  3.945518433294855*^9}},ExpressionUUID->"d61d0268-c142-4982-8fb8-\
11ed23e9a825"],

Cell[BoxData[
 RowBox[{
  RowBox[{"wdis", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"DistanceProfile3D", "[", 
      RowBox[{"mpc", "[", 
       RowBox[{"[", "#", "]"}], "]"}], "]"}], "&"}], "/@", "fwhites"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.945454331583829*^9, 3.945454337043131*^9}, 
   3.9457004560002823`*^9},
 CellLabel->"In[59]:=",ExpressionUUID->"0c948e43-dc27-43ae-a76e-0f6a35d56583"],

Cell["Join to a single dataset ", "Text",
 CellChangeTimes->{{3.945517707043684*^9, 
  3.945517713677453*^9}},ExpressionUUID->"fb179de1-a5c1-409b-bbe6-\
72e54077769f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"whitedistPV", " ", "=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"wdis", "[", 
          RowBox[{"[", "#", "]"}], "]"}], "[", 
         RowBox[{"[", 
          RowBox[{"2", ";;"}], "]"}], "]"}], ",", 
        RowBox[{"wpv", "[", 
         RowBox[{"[", "#", "]"}], "]"}]}], "}"}], "\[Transpose]"}], "&"}], "/@", 
    RowBox[{"Range", "@", 
     RowBox[{"Length", "@", "fwhites"}]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.945455394483564*^9, 3.9454554149892282`*^9}, {
  3.9457004659912577`*^9, 3.945700483916628*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"0603f4c9-344e-4ddf-9de5-1151ad4ad058"],

