Cell["Test for significance ", "Text",
 CellChangeTimes->{{3.946463747161367*^9, 
  3.946463758167603*^9}},ExpressionUUID->"2ae4fb29-9c82-44eb-af99-\
0fd114bfead8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Assuming", " ", "yellowdistspeeds", " ", "data", " ", "is", " ", 
    "structured", " ", "as", " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "y"}], "}"}], " ", "pairs"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ydata", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"yellowdistspeeds", ",", "1"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Fit", " ", "a", " ", "linear", " ", "model"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ymodel", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"ydata", ",", "x", ",", "x"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Show", " ", "the", " ", "plot", " ", "with", " ", "data", " ", "and", " ",
      "regression", " ", "line"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", "\[IndentingNewLine]", "  ", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{"ydata", ",", 
       RowBox[{"PlotStyle", "->", "Red"}], ",", 
       RowBox[{
       "PlotLabel", "->", "\"\<Data with Linear Regression Line\>\""}]}], 
      "]"}], ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"ymodel", "[", "x", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"Min", "[", 
          RowBox[{"ydata", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], ",", 
         RowBox[{"Max", "[", 
          RowBox[{"ydata", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}]}], "\[IndentingNewLine]", 
    "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "parameter", " ", "significance"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"parameterTable", "=", 
     RowBox[{"ymodel", "[", "\"\<ParameterTable\>\"", "]"}]}], ";"}], "\[IndentingNewLine]",
    "parameterTable"}]}]], "Input",
 CellChangeTimes->{{3.946463855418125*^9, 3.946463875005349*^9}, 
   3.946748237923246*^9},
 CellLabel->
  "In[496]:=",ExpressionUUID->"7f5c7ec9-9f95-4e4b-b645-46f4a14f1e87"],

