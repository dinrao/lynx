Cell["Test for significance ", "Text",
 CellChangeTimes->{{3.946463811754466*^9, 
  3.946463815838894*^9}},ExpressionUUID->"239619ec-d4c1-42e6-b7c7-\
33986ffce666"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Assuming", " ", "yellowdistspeeds", " ", "data", " ", "is", " ", 
    "structured", " ", "as", " ", 
    RowBox[{"{", 
     RowBox[{"x", ",", " ", "y"}], "}"}], " ", "pairs"}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"wdata", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"whitedistspeeds", ",", "1"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Fit", " ", "a", " ", "linear", " ", "model"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"wmodel", "=", 
     RowBox[{"LinearModelFit", "[", 
      RowBox[{"wdata", ",", "x", ",", "x"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Show", " ", "the", " ", "plot", " ", "with", " ", "data", " ", "and", " ",
      "regression", " ", "line"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Show", "[", "\[IndentingNewLine]", "  ", 
    RowBox[{
     RowBox[{"ListPlot", "[", 
      RowBox[{"wdata", ",", 
       RowBox[{"PlotStyle", "->", "Red"}], ",", 
       RowBox[{
       "PlotLabel", "->", "\"\<Data with Linear Regression Line\>\""}]}], 
      "]"}], ",", "\[IndentingNewLine]", "  ", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"wmodel", "[", "x", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", 
         RowBox[{"Min", "[", 
          RowBox[{"wdata", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}], ",", 
         RowBox[{"Max", "[", 
          RowBox[{"wdata", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "1"}], "]"}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"PlotStyle", "->", "Blue"}]}], "]"}]}], "\[IndentingNewLine]", 
    "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Extract", " ", "parameter", " ", "significance"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"parameterTable", "=", 
     RowBox[{"wmodel", "[", "\"\<ParameterTable\>\"", "]"}]}], ";"}], "\[IndentingNewLine]",
    "parameterTable"}]}]], "Input",
 CellChangeTimes->{{3.946463822863985*^9, 3.946463848649733*^9}, {
  3.94646388702719*^9, 3.9464639030978727`*^9}},
